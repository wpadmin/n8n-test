# Telegram Client API (получить на https://my.telegram.org)
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_PHONE=+79001234567

# Ngrok Auth Token (получить на https://dashboard.ngrok.com/get-started/your-authtoken)
NGROK_AUTHTOKEN=your_ngrok_token_here

# n8n Authentication (опционально, по умолчанию admin/admin)
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=admin

# Webhook URL (автоматически получается от ngrok)
# WEBHOOK_URL=https://your-domain.ngrok-free.app/